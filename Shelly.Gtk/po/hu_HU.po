msgid "Enable AUR Support"
msgstr "AUR Támogatás Engedélyezése"

msgid "Access the Arch User Repository for a vast collection of community-maintained packages. AUR packages can contain malicious software, so please use caution when using the AUR."
msgstr "Hozzáférés az Arch User Repository oldalához a közösség által karbantartott csomagok hatalmas gyűjteményéhez. Az AUR csomagok tartalmazhatnak rosszindulatú szoftvert, ezért kérjük, legyen óvatos az AUR használatakor."

msgid "Enable Flatpak Support"
msgstr "Flatpak Támogatás Engedélyezése"

msgid "Enable support for Flatpak applications from Flathub and other remotes."
msgstr "A Flatpak alkalmazások támogatásának engedélyezése a Flathubról és más távoli forrásokból."

msgid "Enable AppImage Support"
msgstr "AppImage Támogatás Engedélyezése"

msgid "Manage and configure updates for AppImage applications easily."
msgstr "Egyszerűen kezelheti és konfigurálhatja az AppImage alkalmazások frissítéseit."

msgid "Show a status icon in your system tray for quick access and notifications."
msgstr "Állapot ikon megjelenítése a rendszertálcán a gyors hozzáféréshez és értesítésekhez."

msgid "Vertical Navigation"
msgstr "Függőleges Navigáció"

msgid "Change navigation style to vertical or horizontal style."
msgstr "A navigációs stílus módosítása függőleges vagy vízszintes stílusra."

msgid "Finish Setup"
msgstr "Beállítás Befejezése"

msgid "Any required installations will run after the Finish button has been accepted."
msgstr "A Befejezés gomb elfogadása után minden szükséges telepítés lefut."

msgid "These options and others can be configured later in settings."
msgstr "Ezek és más opciók később a beállításokban konfigurálhatók."

